{
  "name": "gitcharm",
  "displayName": "GitCharm",
  "description": "JetBrains-like Git management for VS Code — Commit panel, Git Log with graph, multi-repo support and more.",
  "version": "0.3.6",
  "publisher": "RioNoir",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/RioNoir/GitCharm.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "scm",
    "commit",
    "log",
    "merge",
    "intellij",
    "phpstorm"
  ],
  "icon": "media/icons/gitcharm.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "workspaceContains:**/.git",
    "onStartupFinished"
  ],
  "main": "./out/host/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitcharm-commit",
          "title": "GitCharm Commit",
          "icon": "media/icons/git-commit.svg"
        }
      ],
      "panel": [
        {
          "id": "gitcharm-log",
          "title": "GitCharm Log",
          "icon": "media/icons/git-merge.svg"
        }
      ]
    },
    "views": {
      "gitcharm-commit": [
        {
          "type": "webview",
          "id": "gitcharm.commitPanel",
          "name": "GitCharm Commit",
          "retainContextWhenHidden": true
        },
        {
          "id": "gitcharm.commitBadge",
          "name": "",
          "when": "false"
        }
      ],
      "gitcharm-log": [
        {
          "type": "webview",
          "id": "gitcharm.gitLog",
          "name": "Git Log",
          "retainContextWhenHidden": true
        }
      ]
    },
    "commands": [
      {
        "command": "gitcharm.openLog",
        "title": "GitCharm: Focus Git Log",
        "shortTitle": "Focus Git Log",
        "icon": "$(history)"
      },
      {
        "command": "gitcharm.commit",
        "title": "GitCharm: Commit"
      },
      {
        "command": "gitcharm.commitAndPush",
        "title": "GitCharm: Commit & Push"
      },
      {
        "command": "gitcharm.pull",
        "title": "GitCharm: Pull"
      },
      {
        "command": "gitcharm.push",
        "title": "GitCharm: Push All",
        "shortTitle": "Push All",
        "icon": "$(repo-push)"
      },
      {
        "command": "gitcharm.fetchAll",
        "title": "GitCharm: Fetch All Remotes",
        "shortTitle": "Fetch All Remotes",
        "icon": "$(repo-fetch)"
      },
      {
        "command": "gitcharm.syncAll",
        "title": "GitCharm: Sync All (Pull + Push)",
        "shortTitle": "Sync All",
        "icon": "$(sync)"
      },
      {
        "command": "gitcharm.openMergeEditor",
        "title": "GitCharm: Open Merge Editor"
      },
      {
        "command": "gitcharm.refreshCommitPanel",
        "title": "GitCharm: Refresh Commit Panel",
        "icon": "$(refresh)"
      },
      {
        "command": "gitcharm.reloadRepositories",
        "title": "GitCharm: Reload Repositories",
        "icon": "$(sync)"
      },
      {
        "command": "gitcharm.showBranchMenu",
        "title": "GitCharm: Branch Menu",
        "shortTitle": "Branch Menu",
        "icon": "$(git-branch)"
      },
      {
        "command": "gitcharm.updateProject",
        "title": "GitCharm: Pull All (Update Project)",
        "shortTitle": "Pull All",
        "icon": "$(repo-pull)"
      },
      {
        "command": "gitcharm.openSettings",
        "title": "GitCharm: Settings",
        "shortTitle": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "gitcharm.openGitAnnotations",
        "title": "GitCharm: Open Git Annotations",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitcharm.closeGitAnnotations",
        "title": "GitCharm: Close Git Annotations",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitcharm.navigateToAnnotationCommit",
        "title": "GitCharm: Navigate to Commit"
      },
      {
        "command": "gitcharm.manageHiddenRepos",
        "title": "GitCharm: Manage Hidden Repositories",
        "icon": "$(eye-closed)"
      },
      {
        "command": "gitcharm.manageProfiles",
        "title": "GitCharm: Manage Git Profiles",
        "icon": "$(account)"
      },
      {
        "command": "gitcharm.switchProfile",
        "title": "GitCharm: Switch Git Profile",
        "icon": "$(account)"
      },
      {
        "command": "gitcharm.submodule.init",
        "title": "GitCharm: Initialize Submodule"
      },
      {
        "command": "gitcharm.submodule.update",
        "title": "GitCharm: Update Submodule"
      },
      {
        "command": "gitcharm.submodule.updateRecursive",
        "title": "GitCharm: Update Submodule (Recursive)"
      },
      {
        "command": "gitcharm.submodule.deinit",
        "title": "GitCharm: Deinit Submodule"
      },
      {
        "command": "gitcharm.submodule.deinitForce",
        "title": "GitCharm: Force Deinit Submodule"
      },
      {
        "command": "gitcharm.submodule.openInNewWindow",
        "title": "GitCharm: Open Submodule in New Window"
      },
      {
        "command": "gitcharm.worktree.add",
        "title": "GitCharm: Add Worktree"
      },
      {
        "command": "gitcharm.worktree.prune",
        "title": "GitCharm: Prune Worktrees"
      },
      {
        "command": "gitcharm.selectAiModel",
        "title": "GitCharm: Select AI Model"
      },
      {
        "command": "gitcharm.showBranchOptions",
        "title": "GitCharm: Branch Options"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitcharm.fetchAll",
          "when": "view == gitcharm.commitPanel",
          "group": "navigation@1"
        },
        {
          "command": "gitcharm.updateProject",
          "when": "view == gitcharm.commitPanel",
          "group": "navigation@2"
        },
        {
          "command": "gitcharm.push",
          "when": "view == gitcharm.commitPanel",
          "group": "navigation@3"
        },
        {
          "command": "gitcharm.syncAll",
          "when": "view == gitcharm.commitPanel",
          "group": "navigation@4"
        },
        {
          "command": "gitcharm.showBranchMenu",
          "when": "view == gitcharm.commitPanel",
          "group": "navigation@5"
        },
        {
          "command": "gitcharm.openLog",
          "when": "view == gitcharm.commitPanel",
          "group": "navigation@6"
        },
        {
          "command": "gitcharm.openSettings",
          "when": "view == gitcharm.commitPanel",
          "group": "navigation@7"
        }
      ],
      "scm/sourceControl": [
        {
          "command": "gitcharm.manageHiddenRepos",
          "group": "gitcharm@1"
        }
      ],
      "commandPalette": [
        { "command": "gitcharm.openLog" },
        { "command": "gitcharm.showBranchMenu" },
        { "command": "gitcharm.commit" },
        { "command": "gitcharm.fetchAll" },
        { "command": "gitcharm.updateProject" },
        { "command": "gitcharm.push" },
        { "command": "gitcharm.syncAll" },
        { "command": "gitcharm.refreshCommitPanel" },
        { "command": "gitcharm.reloadRepositories" },
        { "command": "gitcharm.openMergeEditor" },
        { "command": "gitcharm.manageHiddenRepos" },
        { "command": "gitcharm.manageProfiles" },
        { "command": "gitcharm.switchProfile" },
        { "command": "gitcharm.selectAiModel" },
        { "command": "gitcharm.submodule.init" },
        { "command": "gitcharm.submodule.update" },
        { "command": "gitcharm.submodule.updateRecursive" },
        { "command": "gitcharm.submodule.deinit" },
        { "command": "gitcharm.submodule.deinitForce" },
        { "command": "gitcharm.submodule.openInNewWindow" },
        { "command": "gitcharm.worktree.add" },
        { "command": "gitcharm.worktree.prune" },
        {
          "command": "gitcharm.openGitAnnotations",
          "when": "resourceScheme == file && config.gitcharm.gitAnnotations.enabled"
        },
        {
          "command": "gitcharm.closeGitAnnotations",
          "when": "resourceScheme == file && gitcharm.annotationsVisible"
        },
        { "command": "gitcharm.navigateToAnnotationCommit", "when": "false" },
        { "command": "gitcharm.commitAndPush", "when": "false" },
        { "command": "gitcharm.pull", "when": "false" },
        { "command": "gitcharm.openSettings", "when": "false" },
        { "command": "gitcharm.showBranchOptions", "when": "false" }
      ],
      "editor/lineNumber/context": [
        {
          "command": "gitcharm.openGitAnnotations",
          "when": "resourceScheme == file && config.gitcharm.gitAnnotations.enabled && !gitcharm.annotationsVisible",
          "group": "gitcharm@1"
        },
        {
          "command": "gitcharm.closeGitAnnotations",
          "when": "resourceScheme == file && gitcharm.annotationsVisible",
          "group": "gitcharm@1"
        }
      ],
      "editor/context": [
        {
          "command": "gitcharm.openMergeEditor",
          "when": "resourceScheme == file",
          "group": "gitcharm"
        },
        {
          "command": "gitcharm.openGitAnnotations",
          "when": "resourceScheme == file && config.gitcharm.gitAnnotations.enabled && !gitcharm.annotationsVisible",
          "group": "gitcharm@1"
        },
        {
          "command": "gitcharm.closeGitAnnotations",
          "when": "resourceScheme == file && gitcharm.annotationsVisible",
          "group": "gitcharm@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "gitcharm.openLog",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      },
      {
        "command": "gitcharm.commit",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k"
      }
    ],
    "colors": [
      {
        "id": "gitcharm.statusBarPullForeground",
        "description": "Status bar text color when incoming commits are available (pull needed)",
        "defaults": {
          "dark": "#64b5f6",
          "light": "#1565c0",
          "highContrast": "#64b5f6",
          "highContrastLight": "#1565c0"
        }
      },
      {
        "id": "gitcharm.statusBarPushForeground",
        "description": "Status bar text color when there are unpushed commits or the branch is not on remote",
        "defaults": {
          "dark": "#ce93d8",
          "light": "#6a1b9a",
          "highContrast": "#ce93d8",
          "highContrastLight": "#6a1b9a"
        }
      },
      {
        "id": "gitcharm.statusBarDirtyForeground",
        "description": "Status bar text color when there are uncommitted changes",
        "defaults": {
          "dark": "#81c784",
          "light": "#2e7d32",
          "highContrast": "#81c784",
          "highContrastLight": "#2e7d32"
        }
      }
    ],
    "configuration": [
      {
      "title": "Basic Settings",
      "properties": {
        "gitcharm.graphMaxCommits": {
          "order": 80,
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "Maximum commits to load in the Git Log graph"
        },
        "gitcharm.repositoryScanMaxDepth": {
          "order": 60,
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 10,
          "description": "Maximum depth of workspace subfolders to scan for Git repositories (0 = only workspace folders)."
        },
        "gitcharm.repositoryScanIgnoredFolders": {
          "order": 70,
          "type": "array",
          "default": [
            "node_modules"
          ],
          "items": {
            "type": "string"
          },
          "description": "Folder names or workspace-relative paths to skip while scanning for nested Git repositories."
        },
        "gitcharm.fetchOnStartup": {
          "order": 40,
          "type": "boolean",
          "default": true,
          "description": "Automatically fetch all remotes when the extension activates"
        },
        "gitcharm.notifyOnIncomingCommits": {
          "order": 50,
          "type": "boolean",
          "default": true,
          "description": "Show a notification on startup when there are incoming commits available to pull"
        },
        "gitcharm.notifyOnUnpushedCommits": {
          "order": 55,
          "type": "boolean",
          "default": true,
          "description": "Show a notification on startup when there are unpushed commits ready to push"
        },
        "gitcharm.projectColors": {
          "order": 110,
          "type": "object",
          "default": {},
          "description": "Map of workspace folder/repository name to hex color for the commit graph (e.g. {\"my-repo\": \"#ff6b6b\"})"
        },
        "gitcharm.autoRefreshInterval": {
          "order": 30,
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Auto-refresh interval in seconds (0 = disabled, use file watchers only)"
        },
        "gitcharm.gitAnnotations.enabled": {
          "order": 90,
          "type": "boolean",
          "default": true,
          "description": "Enable Git Annotations in the editor."
        },
        "gitcharm.gitGhostText.enabled": {
          "order": 100,
          "type": "boolean",
          "default": true,
          "description": "Enable inline Git ghost text in the editor."
        },
        "gitcharm.changesViewMode": {
          "order": 10,
          "type": "string",
          "enum": [
            "simplified",
            "changelists",
            "vscode"
          ],
          "enumDescriptions": [
            "Show Staged and Unstaged sections per repository (default behavior)",
            "Show files grouped by Changelists, similar to PhpStorm",
            "Show Staged Changes / Changes sections like native VS Code, with inline stage/unstage buttons"
          ],
          "default": "simplified",
          "description": "How to display changed files in the Changes tab."
        },
        "gitcharm.promptAddUntrackedToGit": {
          "order": 25,
          "type": "boolean",
          "default": true,
          "description": "Show a prompt when new untracked files are detected, offering to add them to Git."
        },
        "gitcharm.defaultCommitAction": {
          "order": 20,
          "type": "string",
          "enum": [
            "commit",
            "commitAndPush"
          ],
          "enumDescriptions": [
            "The main button commits without pushing",
            "The main button commits and pushes immediately"
          ],
          "default": "commit",
          "description": "Default action for the commit button in the Commit Panel."
        },
        "gitcharm.suppressDivergedBranchWarning": {
          "order": 35,
          "type": "boolean",
          "default": false,
          "description": "Suppress the 'Branches have diverged' warning in the Git Menu and status bar."
        }
      }
    },
    {
      "title": "AI Settings",
      "properties": {
        "gitcharm.ai.enabled": {
          "order": 0,
          "type": "boolean",
          "default": true,
          "description": "Enable AI features in GitCharm (commit message generation, commit explanation). When disabled, all AI actions are hidden."
        },
        "gitcharm.ai.language": {
          "order": 1,
          "type": "string",
          "default": "",
          "markdownDescription": "Language for AI-generated text (e.g. `en`, `it`, `fr`, `de`). Leave empty to use the VS Code display language."
        },
        "gitcharm.ai.provider": {
          "order": 2,
          "type": "string",
          "enum": ["vscode-lm", "claude-api", "openai-api", "gemini-api", "claude-cli", "codex-cli", "gemini-cli", "ollama", "lmstudio"],
          "enumDescriptions": [
            "Use VS Code Language Model API (GitHub Copilot or any registered LM extension)",
            "Use Anthropic API directly (requires API key)",
            "Use OpenAI API directly (requires API key)",
            "Use Google Gemini API directly (requires API key)",
            "Use Claude CLI (claude --print)",
            "Use Codex CLI (codex exec)",
            "Use Gemini CLI (gemini -p)",
            "Use a local Ollama model via HTTP API",
            "Use a local LM Studio model via HTTP API"
          ],
          "default": "vscode-lm",
          "description": "AI provider to use for all AI features."
        },
        "gitcharm.ai.modelId": {
          "order": 2,
          "type": "string",
          "default": "",
          "description": "VS Code LM model ID (e.g. 'copilot:gpt-4o'). Only used when provider is 'vscode-lm'. Leave empty to auto-select. Use the 'GitCharm: Select AI Model' command to pick interactively."
        },
        "gitcharm.ai.claudeApiKey": {
          "order": 3,
          "type": "string",
          "default": "",
          "description": "Anthropic API key. Only used when provider is 'claude-api'. Get your key at console.anthropic.com."
        },
        "gitcharm.ai.claudeModel": {
          "order": 4,
          "type": "string",
          "default": "",
          "description": "Claude model ID (e.g. 'claude-opus-4-7', 'claude-sonnet-4-6'). Used when provider is 'claude-api' or 'claude-cli'. Leave empty to use the default. Use the 'GitCharm: Select AI Model' command to pick interactively."
        },
        "gitcharm.ai.claudePath": {
          "order": 5,
          "type": "string",
          "default": "claude",
          "description": "Path to the Claude CLI binary. Only used when provider is 'claude-cli'. Defaults to 'claude' (must be on PATH)."
        },
        "gitcharm.ai.openaiApiKey": {
          "order": 6,
          "type": "string",
          "default": "",
          "description": "OpenAI API key. Only used when provider is 'openai-api'. Get your key at platform.openai.com."
        },
        "gitcharm.ai.openaiModel": {
          "order": 7,
          "type": "string",
          "default": "gpt-4o",
          "description": "OpenAI model ID (e.g. 'gpt-4o', 'gpt-4o-mini', 'o3'). Only used when provider is 'openai-api'."
        },
        "gitcharm.ai.geminiApiKey": {
          "order": 8,
          "type": "string",
          "default": "",
          "description": "Google Gemini API key. Only used when provider is 'gemini-api'. Get your key at aistudio.google.com."
        },
        "gitcharm.ai.geminiModel": {
          "order": 9,
          "type": "string",
          "default": "gemini-2.0-flash",
          "description": "Gemini model ID (e.g. 'gemini-2.0-flash', 'gemini-2.5-pro'). Used when provider is 'gemini-api' or 'gemini-cli'."
        },
        "gitcharm.ai.geminiPath": {
          "order": 10,
          "type": "string",
          "default": "gemini",
          "description": "Path to the Gemini CLI binary. Only used when provider is 'gemini-cli'. Defaults to 'gemini' (must be on PATH)."
        },
        "gitcharm.ai.codexModel": {
          "order": 11,
          "type": "string",
          "default": "",
          "description": "Codex model ID to use (e.g. 'o3', 'o4-mini'). Only used when provider is 'codex-cli'. Leave empty to use the CLI default. Use the 'GitCharm: Select AI Model' command to pick interactively."
        },
        "gitcharm.ai.codexPath": {
          "order": 9,
          "type": "string",
          "default": "codex",
          "description": "Path to the Codex CLI binary. Only used when provider is 'codex-cli'. Defaults to 'codex' (must be on PATH)."
        },
        "gitcharm.ai.lmStudioModel": {
          "order": 7,
          "type": "string",
          "default": "",
          "description": "LM Studio model identifier. Only used when provider is 'lmstudio'. Leave empty to use the currently loaded model. Use the 'GitCharm: Select AI Model' command to pick interactively."
        },
        "gitcharm.ai.lmStudioUrl": {
          "order": 8,
          "type": "string",
          "default": "http://localhost:1234",
          "description": "Base URL of the LM Studio local server. Only used when provider is 'lmstudio'."
        },
        "gitcharm.ai.ollamaModel": {
          "order": 11,
          "type": "string",
          "default": "llama3",
          "description": "Ollama model name (e.g. 'llama3', 'mistral', 'qwen3.5:9b'). Only used when provider is 'ollama'."
        },
        "gitcharm.ai.ollamaUrl": {
          "order": 12,
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL of the Ollama API. Only used when provider is 'ollama'."
        },
        "gitcharm.ai.maxDiffChars": {
          "order": 13,
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "maximum": 100000,
          "description": "Maximum characters of git diff to send to the AI model. Larger values give more context but consume more tokens."
        }
      }
    }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:host && npm run build:webview",
    "build:host": "node esbuild.mjs --prod",
    "build:webview": "node build-webview.mjs",
    "watch": "concurrently \"npm run watch:host\" \"npm run watch:webview\"",
    "watch:host": "node esbuild.mjs --watch",
    "watch:webview": "node build-webview.mjs --watch",
    "package": "vsce package",
    "publish": "vsce publish",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:webview": "tsc --noEmit -p tsconfig.webview.json"
  },
  "dependencies": {
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@tanstack/react-virtual": "^3.2.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vscode/codicons": "^0.0.45",
    "@vscode/vsce": "^2.24.0",
    "concurrently": "^8.2.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.56.0",
    "material-icon-theme": "^5.34.0",
    "monaco-editor": "^0.47.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^7.0.0",
    "zustand": "^4.5.0"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.20.0",
    "@esbuild/linux-arm64": "^0.20.0",
    "@rollup/rollup-darwin-arm64": "^4.60.4"
  }
}
